<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#000000">
  <title>OutCastLabs — All Work</title>
  <meta name="description" content="OutCastLabs selected work and case studies.">
  <link rel="icon" href="/favicons/smallfavicon.png" sizes="16x16" type="image/png">
  <link rel="icon" href="/favicons/mediumfavicon.png" sizes="32x32" type="image/png">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <header class="Nav-module-scss-module__Ui4UsW__root">
    <div class="Nav-module-scss-module__Ui4UsW__container">
      <a href="/" class="Nav-module-scss-module__Ui4UsW__logoLink" aria-label="OutCastLabs home">
        <span class="vanta-logo">OutCastLabs</span>
      </a>
      <nav class="Nav-module-scss-module__Ui4UsW__desktopNav">
        <a class="Nav-module-scss-module__Ui4UsW__navLink" href="/">Home</a>
        <a class="Nav-module-scss-module__Ui4UsW__navLink" href="/#approach">Approach</a>
        <a class="Nav-module-scss-module__Ui4UsW__navLink" href="/#whyus">Why us</a>
        <a class="Nav-module-scss-module__Ui4UsW__navLink" href="/#pricing">Pricing</a>
      </nav>
    </div>
  </header>

  <main class="page-content">
    <section id="works">
      <div class="Grid-module-scss-module__OPYCKW__grid work-header" style="--cols:8">
        <div class="Grid-module-scss-module__OPYCKW__content">
          <div class="Grid-module-scss-module__OPYCKW__item" style="grid-column: 1 / span 5">
            <h2 class="heading">All Work</h2>
          </div>
          <div class="Grid-module-scss-module__OPYCKW__item note" style="grid-column: 6 / span 3">
            <p>Explore our full case study library and selected design work across branding, web, and mobile.</p>
          </div>
        </div>
      </div>

      <div class="work-cards">
        <div class="Grid-module-scss-module__OPYCKW__grid" style="--cols:8">
          <div class="Grid-module-scss-module__OPYCKW__content" style="gap:1.5rem 0.75rem">
            <div class="Grid-module-scss-module__OPYCKW__item work-card" style="grid-column: 1 / span 4; grid-row: 1">
              <a class="work-card-link" href="/work/woodpecker-bar.html">
                <div class="work-card-image">
                  <div class="work-card-image-inner">
                    <img src="/case-studies/woodpecker-bar.png" alt="Wood Pecker Bar — Lucknow">
                  </div>
                </div>
                <div class="work-card-label">
                  <div class="work-card-label-text">
                    <span>Wood Pecker Bar — Lucknow</span>
                    <span>Web Design · Branding · UI/UX</span>
                  </div>
                  <div class="work-card-arrow"><svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M10.0208 3.41421L1.41421 12.0208L0 10.6066L8.60659 2H1.02082V0H12.0208V11H10.0208V3.41421Z" fill="white"/></svg></div>
                </div>
              </a>
            </div>
            <div class="Grid-module-scss-module__OPYCKW__item work-card" style="grid-column: 5 / span 4; grid-row: 1">
              <a class="work-card-link" href="/work/hikari.html">
                <div class="work-card-image">
                  <div class="work-card-image-inner">
                    <img src="/case-studies/hikari-restaurant.jpg" alt="Hikari Modern Restaurant">
                  </div>
                </div>
                <div class="work-card-label">
                  <div class="work-card-label-text">
                    <span>Hikari Modern Restaurant</span>
                    <span>Web Design · Branding · Motion</span>
                  </div>
                  <div class="work-card-arrow"><svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M10.0208 3.41421L1.41421 12.0208L0 10.6066L8.60659 2H1.02082V0H12.0208V11H10.0208V3.41421Z" fill="white"/></svg></div>
                </div>
              </a>
            </div>
            <div class="Grid-module-scss-module__OPYCKW__item work-card" style="grid-column: 1 / span 4; grid-row: 2">
              <a class="work-card-link" href="/work/fivemonkey.html">
                <div class="work-card-image">
                  <div class="work-card-image-inner">
                    <img src="/case-studies/fivemonkey.png" alt="5Monkey — Classy Cuisine">
                  </div>
                </div>
                <div class="work-card-label">
                  <div class="work-card-label-text">
                    <span>5Monkey — Classy Cuisine</span>
                    <span>Web Design · CMS · Branding</span>
                  </div>
                  <div class="work-card-arrow"><svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M10.0208 3.41421L1.41421 12.0208L0 10.6066L8.60659 2H1.02082V0H12.0208V11H10.0208V3.41421Z" fill="white"/></svg></div>
                </div>
              </a>
            </div>
            <div class="Grid-module-scss-module__OPYCKW__item work-card" style="grid-column: 5 / span 4; grid-row: 2">
              <a class="work-card-link" href="/work/oreos.html">
                <div class="work-card-image">
                  <div class="work-card-image-inner">
                    <img src="/case-studies/oreos-cafe.png" alt="Oreos Café & Bistro">
                  </div>
                </div>
                <div class="work-card-label">
                  <div class="work-card-label-text">
                    <span>Oreos Café & Bistro</span>
                    <span>Web Design · Menu UI · Branding</span>
                  </div>
                  <div class="work-card-arrow"><svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M10.0208 3.41421L1.41421 12.0208L0 10.6066L8.60659 2H1.02082V0H12.0208V11H10.0208V3.41421Z" fill="white"/></svg></div>
                </div>
              </a>
            </div>
            <div class="Grid-module-scss-module__OPYCKW__item work-card" style="grid-column: 1 / span 4; grid-row: 3">
              <a class="work-card-link" href="/work/yuan.html">
                <div class="work-card-image">
                  <div class="work-card-image-inner">
                    <img src="/case-studies/yuan/cover.png" alt="YUÁN Chinese Restaurant">
                  </div>
                </div>
                <div class="work-card-label">
                  <div class="work-card-label-text">
                    <span>YUÁN Chinese Restaurant</span>
                    <span>Web Design · Menu UI · Branding</span>
                  </div>
                  <div class="work-card-arrow"><svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M10.0208 3.41421L1.41421 12.0208L0 10.6066L8.60659 2H1.02082V0H12.0208V11H10.0208V3.41421Z" fill="white"/></svg></div>
                </div>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <script src="/script.js"></script>
</body>
</html>
