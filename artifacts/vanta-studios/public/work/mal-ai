UHLsGA4 2048w, /_next/image?url=%2Fcase-studies%2Fmal-ai%2Flarge-banner.png&amp;w=3840&amp;q=75&amp;dpl=dpl_A6aUt6FdMbVkQ1PPeFnRbUHLsGA4 3840w" src="/_next/image?url=%2Fcase-studies%2Fmal-ai%2Flarge-banner.png&amp;w=3840&amp;q=75&amp;dpl=dpl_A6aUt6FdMbVkQ1PPeFnRbUHLsGA4"/></div><div class="work-case-body"><aside class="work-case-sidebar" aria-label="Project details"><p class="work-case-eyebrow">Mal AI</p><dl class="work-case-meta"><div class="work-case-meta-row"><dt>Timeline</dt><dd>4 weeks</dd></div><div class="work-case-meta-row"><dt id="work-case-categories-mal-ai">Categories</dt><dd><ul class="work-case-category-list" aria-labelledby="work-case-categories-mal-ai"><li>Brand Exploration</li><li>Art Direction</li><li>Visual Systems</li><li>Islamic Finance</li></ul></dd></div><div class="work-case-meta-row"><dt>Location</dt><dd>Global · Remote</dd></div><div class="work-case-meta-row"><dt>Year</dt><dd>2026</dd></div></dl></aside><div class="work-case-main"><div class="work-case-intro"><h1 class="work-case-title" id="work-case-title"><span class="TextReveal-module-scss-module__WSa0mG__line" data-text-reveal-line="true"><span class="TextReveal-module-scss-module__WSa0mG__inner" data-text-reveal-inner="true" style="filter:blur(14px);opacity:0;transform:translateY(22px)">A global Islamic finance brand,</span></span><span class="TextReveal-module-scss-module__WSa0mG__line" data-text-reveal-line="true"><span class="TextReveal-module-scss-module__WSa0mG__inner" data-text-reveal-inner="true" style="filter:blur(14px);opacity:0;transform:translateY(22px)">built to scale with clarity</span></span></h1><p class="work-case-lede">Mal AI arrived with an established identity and a clear ambition: grow the brand ecosystem with assets that feel modern, trustworthy, and unmistakably rooted in Islamic finance. We led a client-side brand exploration — from narrative anchors to physical and social touchpoints — so every expression could travel globally while staying faithful to the values at the company’s foundation.</p></div><div class="work-case-sections"><section class="CaseStudySection-module-scss-module__KrPwpG__section" aria-labelledby="_R_qislubsnlnb_" aria-describedby="_R_qislubsnlnbH1_"><div class="CaseStudySection-module-scss-module__KrPwpG__inner"><div class="CaseStudySection-module-scss-module__KrPwpG__intro"><h2 id="_R_qislubsnlnb_" class="CaseStudySection-module-scss-module__KrPwpG__title">Brief</h2><p id="_R_qislubsnlnbH1_" class="CaseStudySection-module-scss-module__KrPwpG__subtitle">Expand the ecosystem without diluting the brand</p><p class="CaseStudySection-module-scss-module__KrPwpG__paragraph">This was not a blank page. Mal AI already had a recognizable brand; the work was to stretch it into a fuller toolkit — graphics, layouts, and applications — that product, marketing, and partners could reuse with confidence. We focused on coherence: one voice across channels, with enough range to feel alive in real campaigns and physical spaces.</p></div><div class="CaseStudySection-module-scss-module__KrPwpG__figureWrap"><figure class="CaseStudySection-module-scss-module__KrPwpG__figure"><div class="CaseStudySection-module-scss-module__KrPwpG__imageFrame"><img alt="Mal AI brand exploration" loading="lazy" width="1600" height="900" decoding="async" data-nimg="1" class="CaseStudySection-module-scss-module__KrPwpG__image" style="color:transparent" sizes="(min-width: 768px) 50vw, 100vw" srcSet="/_next/image?url=%2Fcase-studies%2Fmal-ai%2Fbrand-exploration.webp&amp;w=384&amp;q=75&amp;dpl=dpl_A6aUt6FdMbVkQ1PPeFnRbUHLsGA4 384w, /_next/image?url=%2Fcase-studies%2Fmal-ai%2Fbrand-exploration.webp&amp;w=640&amp;q=75&amp;dpl=dpl_A6aUt6FdMbVkQ1PPeFnRbUHLsGA4 640w, /_next/image?url=%2Fcase-studies%2Fmal-ai%2Fbrand-exploration.webp&amp;w=750&amp;q=75&amp;dpl=dpl_A6aUt6FdMbVkQ1PPeFnRbUHLsGA4 750w, /_next/image?url=%2Fcase-studies%2Fmal-ai%2Fbrand-exploration.webp&amp;w=828&amp;q=75&amp;dpl=dpl_A6aUt6FdMbVkQ1PPeFnRbUHLsGA4 828w, /_next/image?url=%2Fcase-studies%2Fmal-ai%2Fbrand-exploration.webp&amp;w=1080&amp;q=75&amp;dpl=dpl_A6aUt6FdMbVkQ1PPeFnRbUHLsGA4 1080w, /_next/image?url=%2Fcase-studies%2Fmal-ai%2Fbrand-exploration.webp&amp;w=1200&amp;q=75&amp;dpl=dpl_A6aUt6FdMbVkQ1PPeFnRbUHLsGA4 1200w, /_next/image?url=%2Fcase-studies%2Fmal-ai%2Fbrand-exploration.webp&amp;w=1920&amp;q=75&amp;dpl=dpl_A6aUt6FdMbVkQ1PPeFnRbUHLsGA4 1920w, /_next/image?url=%2Fcase-studies%2Fmal-ai%2Fbrand-exploration.webp&amp;w=2048&amp;q=75&amp;dpl=dpl_A6aUt6FdMbVkQ1PPeFnRbUHLsGA4 2048w, /_next/image?url=%2Fcase-studies%2Fmal-ai%2Fbrand-exploration.webp&amp;w=3840&amp;q=75&amp;dpl=dpl_A6aUt6FdMbVkQ1PPeFnRbUHLsGA4 3840w" src="/_next/image?url=%2Fcase-studies%2Fmal-ai%2Fbrand-exploration.webp&amp;w=3840&amp;q=75&amp;dpl=dpl_A6aUt6FdMbVkQ1PPeFnRbUHLsGA4"/></div></figure></div></div></section><section class="CaseStudySection-module-scss-module__KrPwpG__section" aria-labelledby="_R_1aislubsnlnb_" aria-describedby="_R_1aislubsnlnbH1_"><div class="CaseStudySection-module-scss-module__KrPwpG__inner"><div class="CaseStudySection-module-scss-module__KrPwpG__intro"><h2 id="_R_1aislubsnlnb_" class="CaseStudySection-module-scss-module__KrPwpG__title">Islamic foundation</h2><p id="_R_1aislubsnlnbH1_" class="CaseStudySection-module-scss-module__KrPwpG__subtitle">Global reach, values at the core</p><p class="CaseStudySection-module-scss-module__KrPwpG__paragraph">Mal AI is built as an Islamic banking solution: worldwide in ambition, but always anchored in principles that matter to its audience. We made that foundation visible in the work — not as decoration, but as structure. The brand had to read as contemporary fintech while signalling trust, fairness, and restraint in line with what clients expect from Sharia-aligned finance.</p></div></div></section><section class="CaseStudySection-module-scss-module__KrPwpG__section" aria-labelledby="_R_1qislubsnlnb_" aria-describedby="_R_1qislubsnlnbH1_"><div class="CaseStudySection-module-scss-module__KrPwpG__inner"><div class="CaseStudySection-module-scss-module__KrPwpG__intro"><h2 id="_R_1qislubsnlnb_" class="CaseStudySection-module-scss-module__KrPwpG__title">Islamic Grid</h2><p id="_R_1qislubsnlnbH1_" class="CaseStudySection-module-scss-module__KrPwpG__subtitle">Adl, Amanah, Barakah, Tawazun</p><p class="CaseStudySection-module-scss-module__KrPwpG__paragraph">We introduced a unifying graphic asset — the Islamic Grid — that carries the brand’s moral compass into layout and storytelling. Each quadrant aligns with a value: Adl (justice), Amanah (trustworthiness), Barakah (blessing and thriving), and Tawazun (balance). Together they form a repeatable scaffold for key visuals, campaigns, and interface-adjacent surfaces so the identity stays legible whether the context is subtle or bold.</p></div><div class="CaseStudySection-module-scss-module__KrPwpG__figureWrap"><figure class="CaseStudySection-module-scss-module__KrPwpG__figure"><div class="CaseStudySection-module-scss-module__KrPwpG__imageFrame"><video class="CaseStudySection-module-scss-module__KrPwpG__image" src="/case-studies/mal-ai/islamic-grid.webm" autoPlay="" muted="" loop="" playsInline="" aria-label="Mal AI Islamic foundation"></video></div></figure></div></div></section><section class="CaseStudySection-module-scss-module__KrPwpG__section" aria-labelledby="_R_2aislubsnlnb_" aria-describedby="_R_2aislubsnlnbH1_"><div class="CaseStudySection-module-scss-module__KrPwpG__inner"><div class="CaseStudySection-module-scss-module__KrPwpG__intro"><h2 id="_R_2aislubsnlnb_" class="CaseStudySection-module-scss-module__KrPwpG__title">Latin &amp; Arabic</h2><p id="_R_2aislubsnlnbH1_" class="CaseStudySection-module-scss-module__KrPwpG__subtitle">One typographic voice, two scripts</p><p class="CaseStudySection-module-scss-module__KrPwpG__paragraph">Islamic finance speaks to diverse regions; bilingual expression was essential. We set the system in Aeonik for its balanced Latin and Arabic cuts, so headlines and supporting copy could switch scripts without breaking rhythm or hierarchy. Across the most visible creative assets, we showed both Latin and Arabic side by side — reinforcing that this is a global brand with an inclusive, intentional voice.</p></div><div class="CaseStudySection-module-scss-module__KrPwpG__figureWrap"><figure class="CaseStudySection-module-scss-module__KrPwpG__figure"><div class="CaseStudySection-module-scss-module__KrPwpG__imageFrame"><img alt="Mal AI Latin &amp; Arabic" loading="lazy" width="1600" height="900" decoding="async" data-nimg="1" class="CaseStudySection-module-scss-module__KrPwpG__image" style="color:transparent" sizes="(min-width: 768px) 50vw, 100vw" srcSet="/_next/image?url=%2Fcase-studies%2Fmal-ai%2Fbilingual.webp&amp;w=384&amp;q=75&amp;dpl=dpl_A6aUt6FdMbVkQ1PPeFnRbUHLsGA4 384w, /_next/image?url=%2Fcase-studies%2Fmal-ai%2Fbilingual.webp&amp;w=640&amp;q=75&amp;dpl=dpl_A6aUt6FdMbVkQ1PPeFnRbUHLsGA4 640w, /_next/image?url=%2Fcase-studies%2Fmal-ai%2Fbilingual.webp&amp;w=750&amp;q=75&amp;dpl=dpl_A6aUt6FdMbVkQ1PPeFnRbUHLsGA4 750w, /_next/image?url=%2Fcase-studies%2Fmal-ai%2Fbilingual.webp&amp;w=828&amp;q=75&amp;dpl=dpl_A6aUt6FdMbVkQ1PPeFnRbUHLsGA4 828w, /_next/image?url=%2Fcase-studies%2Fmal-ai%2Fbilingual.webp&amp;w=1080&amp;q=75&amp;dpl=dpl_A6aUt6FdMbVkQ1PPeFnRbUHLsGA4 1080w, /_next/image?url=%2Fcase-studies%2Fmal-ai%2Fbilingual.webp&amp;w=1200&amp;q=75&amp;dpl=dpl_A6aUt6FdMbVkQ1PPeFnRbUHLsGA4 1200w, /_next/image?url=%2Fcase-studies%2Fmal-ai%2Fbilingual.webp&amp;w=1920&amp;q=75&amp;dpl=dpl_A6aUt6FdMbVkQ1PPeFnRbUHLsGA4 1920w, /_next/image?url=%2Fcase-studies%2Fmal-ai%2Fbilingual.webp&amp;w=2048&amp;q=75&amp;dpl=dpl_A6aUt6FdMbVkQ1PPeFnRbUHLsGA4 2048w, /_next/image?url=%2Fcase-studies%2Fmal-ai%2Fbilingual.webp&amp;w=3840&amp;q=75&amp;dpl=dpl_A6aUt6FdMbVkQ1PPeFnRbUHLsGA4 3840w" src="/_next/image?url=%2Fcase-studies%2Fmal-ai%2Fbilingual.webp&amp;w=3840&amp;q=75&amp;dpl=dpl_A6aUt6FdMbVkQ1PPeFnRbUHLsGA4"/></div></figure></div></div></section><section class="CaseStudySection-module-scss-module__KrPwpG__section" aria-labelledby="_R_2qislubsnlnb_" aria-describedby="_R_2qislubsnlnbH1_"><div class="CaseStudySection-module-scss-module__KrPwpG__inner"><div class="CaseStudySection-module-scss-module__KrPwpG__intro"><h2 id="_R_2qislubsnlnb_" class="CaseStudySection-module-scss-module__KrPwpG__title">Card progression</h2><p id="_R_2qislubsnlnbH1_" class="CaseStudySection-module-scss-module__KrPwpG__subtitle">Four tiers, one clear ladder</p><p class="CaseStudySection-module-scss-module__KrPwpG__paragraph">The card programme needed a distinguished hierarchy: not just different colors, but a progression people recognize at a glance. We defined four levels — Mal (standard plastic), Mal Metal, Mal Gold, and Mal Black Metal — each with its own finish, contrast, and detail while sharing a single design DNA. The result is a lineup that feels premium and orderly, with status communicated through material and craft rather than noise.</p></div><div class="CaseStudySection-module-scss-module__KrPwpG__figureWrap"><figure class="CaseStudySection-module-scss-module__KrPwpG__figure"><div class="CaseStudySection-module-scss-module__KrPwpG__imageFrame"><video class="CaseStudySection-module-scss-module__KrPwpG__image" src="/case-studies/mal-ai/cards.webm" autoPlay="" muted="" loop="" playsInline="" aria-label="Mal AI Card progression"></video></div></figure></div></div></section><section class="CaseStudySection-module-scss-module__KrPwpG__section" aria-labelledby="_R_3aislubsnlnb_" aria-describedby="_R_3aislubsnlnbH1_"><div class="CaseStudySection-module-scss-module__KrPwpG__inner"><div class="CaseStudySection-module-scss-module__KrPwpG__intro"><h2 id="_R_3aislubsnlnb_" class="CaseStudySection-module-scss-module__KrPwpG__title">Presence</h2><p id="_R_3aislubsnlnbH1_" class="CaseStudySection-module-scss-module__KrPwpG__subtitle">From merch and streets to feeds and the homepage</p><p class="CaseStudySection-module-scss-module__KrPwpG__paragraph">To stress-test the system, we carried the identity into physical and social contexts: merchandise, outdoor advertising, social media mockups, and a hero section for the site. Each format had to prove that the Islamic Grid, typography, and card language could scale — whether someone sees a poster across the street, a story on their phone, or the first fold of the product story online.</p></div><div class="CaseStudySection-module-scss-module__KrPwpG__figureWrap"><figure class="CaseStudySection-module-scss-module__KrPwpG__figure"><div class="CaseStudySection-module-scss-module__KrPwpG__imageFrame"><img alt="Mal AI Presence" loading="lazy" width="1600" height="900" decoding="async" data-nimg="1" class="CaseStudySection-module-scss-module__KrPwpG__image" style="color:transparent" sizes="(min-width: 768px) 50vw, 100vw" srcSet="/_next/image?url=%2Fcase-studies%2Fmal-ai%2Fwebsite.webp&amp;w=384&amp;q=75&amp;dpl=dpl_A6aUt6FdMbVkQ1PPeFnRbUHLsGA4 384w, /_next/image?url=%2Fcase-studies%2Fmal-ai%2Fwebsite.webp&amp;w=640&amp;q=75&amp;dpl=dpl_A6aUt6FdMbVkQ1PPeFnRbUHLsGA4 640w, /_next/image?url=%2Fcase-studies%2Fmal-ai%2Fwebsite.webp&amp;w=750&amp;q=75&amp;dpl=dpl_A6aUt6FdMbVkQ1PPeFnRbUHLsGA4 750w, /_next/image?url=%2Fcase-studies%2Fmal-ai%2Fwebsite.webp&amp;w=828&amp;q=75&amp;dpl=dpl_A6aUt6FdMbVkQ1PPeFnRbUHLsGA4 828w, /_next/image?url=%2Fcase-studies%2Fmal-ai%2Fwebsite.webp&amp;w=1080&amp;q=75&amp;dpl=dpl_A6aUt6FdMbVkQ1PPeFnRbUHLsGA4 1080w, /_next/image?url=%2Fcase-studies%2Fmal-ai%2Fwebsite.webp&amp;w=1200&amp;q=75&amp;dpl=dpl_A6aUt6FdMbVkQ1PPeFnRbUHLsGA4 1200w, /_next/image?url=%2Fcase-studies%2Fmal-ai%2Fwebsite.webp&amp;w=1920&amp;q=75&amp;dpl=dpl_A6aUt6FdMbVkQ1PPeFnRbUHLsGA4 1920w, /_next/image?url=%2Fcase-studies%2Fmal-ai%2Fwebsite.webp&amp;w=2048&amp;q=75&amp;dpl=dpl_A6aUt6FdMbVkQ1PPeFnRbUHLsGA4 2048w, /_next/image?url=%2Fcase-studies%2Fmal-ai%2Fwebsite.webp&amp;w=3840&amp;q=75&amp;dpl=dpl_A6aUt6FdMbVkQ1PPeFnRbUHLsGA4 3840w" src="/_next/image?url=%2Fcase-studies%2Fmal-ai%2Fwebsite.webp&amp;w=3840&amp;q=75&amp;dpl=dpl_A6aUt6FdMbVkQ1PPeFnRbUHLsGA4"/></div></figure></div></div></section></div></div></div></header><div class="work-case-footer-cta"><div class="Grid-module-scss-module__OPYCKW__grid work-cards work-case-more-grid" style="--cols:8"><div class="Grid-module-scss-module__OPYCKW__content" style="gap:0.75rem"><div class="Grid-module-scss-module__OPYCKW__item work-card work-card--feature work-case-more-card" style="grid-column:1 / span 3;grid-row:1"><a class="work-card-link" href="/work/nr8"><div class="work-card-image"><img src="/case-studies/nr8/banner.webp" alt="NR8 Global — Creative Studio"/></div><div class="work-card-label"><div class="work-card-label-text"><span>NR8 Global<!-- --> — <!-- -->Creative Studio</span><span>Web Design &amp; Dev.</span></div><div class="work-card-arrow"><svg width="13" height="13" viewBox="0 0 13 13" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M10.0208 3.41421L1.41421 12.0208L0 10.6066L8.60659 2H1.02082V0H12.0208V11H10.0208V3.41421Z" fill="black"></path></svg></div></div></a></div><div class="Grid-module-scss-module__OPYCKW__item work-footer work-case-more-footer" style="grid-column:6 / span 3;grid-row:1"><a class="view-all" href="/works">View all</a></div></div></div></div></article></section><div id="footer-plax"></div><footer id="Footer-module-scss-module__JLT4gq__footer"><div class="Footer-module-scss-module__JLT4gq__inner"><div class="Footer-module-scss-module__JLT4gq__top"><nav class="Footer-module-scss-module__JLT4gq__nav"><a href="/works" class="HoverTextLink-module-scss-module__6DeKsq__link Footer-module-scss-module__JLT4gq__footerLink"><div class="HoverTextLink-module-scss-module__6DeKsq__textWrap"><span class="HoverTextLink-module-scss-module__6DeKsq__textVisible" style="transform:none">Work</span><span class="HoverTextLink-module-scss-module__6DeKsq__textHidden" aria-hidden="true" style="transform:translateY(100%)">Work</span></div></a><a href="/#approach" class="HoverTextLink-module-scss-module